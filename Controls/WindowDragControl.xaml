<UserControl x:Class="POECraftHelper.Controls.WindowDragControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:POECraftHelper.Controls"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             mc:Ignorable="d">

  <Grid Width="30"
        Height="30"
        MouseLeftButtonDown="Ellipse_MouseLeftButtonDown"
        MouseEnter="Ellipse_MouseEnter"
        MouseLeave="Ellipse_MouseLeave">
    <Ellipse Fill="#3b3938"
             Width="30"
             Height="30"/>
    <mah:FontIcon FontFamily="Segoe MDL2 Assets"
                  Glyph="&#xE7C2;"
                  Foreground="#fcba1e"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  FontSize="25"
                  IsEnabled="{Binding IsDragEnabled, RelativeSource={RelativeSource AncestorType=UserControl}}">
      <mah:FontIcon.Style>
        <Style TargetType="mah:FontIcon">
          <Setter Property="Opacity"
                  Value="1" />
          <Style.Triggers>
            <Trigger Property="IsEnabled"
                     Value="False">
              <Setter Property="Opacity"
                      Value="0.3" />
            </Trigger>
          </Style.Triggers>
        </Style>
      </mah:FontIcon.Style>
      <mah:FontIcon.RenderTransform>
        <TranslateTransform X="1"
                            Y="1" />
      </mah:FontIcon.RenderTransform>
    </mah:FontIcon>
  </Grid>

</UserControl>
