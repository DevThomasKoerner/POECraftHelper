<mah:MetroWindow x:Class="POECraftHelper.Dialogs.SettingsDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:local="clr-namespace:POECraftHelper.Dialogs"
                 xmlns:converters="clr-namespace:POECraftHelper.Converters"
                 xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
                 xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
                 mc:Ignorable="d"
                 WindowStyle="None"
                 WindowStartupLocation="Manual"
                 WindowTitleBrush="#FF2C2C2C"
                 TitleCharacterCasing="Normal"
                 Title="Settings"
                 ShowCloseButton="True"
                 ShowMaxRestoreButton="False"
                 ShowMinButton="False"
                 ShowInTaskbar="false"
                 ResizeMode="CanResize"
                 BorderThickness="0"
                 Topmost="True"
                 Height="{Binding WindowHeight, Mode=TwoWay}"
                 Width="{Binding WindowWidth, Mode=TwoWay}"
                 Left="{Binding WindowLeft, Mode=TwoWay}"
                 Top="{Binding WindowTop, Mode=TwoWay}"
                 MinWidth="240"
                 MinHeight="200">

  <mah:MetroWindow.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Controls.xaml" />
        <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Fonts.xaml" />
        <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Themes/Dark.Amber.xaml" />
      </ResourceDictionary.MergedDictionaries>

      <converters:BoolToVisibilityConverter x:Key="_boolToVisibilityConverter" />
    </ResourceDictionary>
  </mah:MetroWindow.Resources>

  <Grid>

    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <ScrollViewer Grid.Row="0">
      <Grid Margin="0,0,5,0">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="10" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="10" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="10" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Expander Header="Sound"
                  Grid.Row="0"
                  IsExpanded="{Binding IsSoundExpanded, Mode=TwoWay}"
                  Margin="10">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <CheckBox Grid.Row="0"
                      HorizontalAlignment="Left"
                      Content="Enable Sound"
                      IsChecked="{Binding SoundEnabled}"
                      Margin="20,0,0,0" />

            <Grid Grid.Row="1"
                  Margin="20,5,0,0"
                  Width="200"
                  HorizontalAlignment="Left">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>

              <TextBlock Text="{Binding ElementName=MySlider, Path=Value, StringFormat={}{0:0}%}"
                         Margin="0,0,10,0"
                         FontSize="12"
                         VerticalAlignment="Center"
                         HorizontalAlignment="Left"
                         Grid.Column="0" />
              <Slider x:Name="MySlider"
                      Minimum="0"
                      Maximum="100"
                      Value="{Binding SoundVolume}"
                      TickFrequency="0.1"
                      IsSnapToTickEnabled="True"
                      IsEnabled="{Binding CanChangeSoundVolume}"
                      Grid.Column="1">
                <Slider.Style>
                  <Style TargetType="Slider"
                         BasedOn="{StaticResource {x:Type Slider}}">
                    <Style.Triggers>
                      <Trigger Property="UIElement.IsEnabled"
                               Value="False">
                        <Setter Property="Opacity"
                                Value="0.4" />
                      </Trigger>
                    </Style.Triggers>
                  </Style>
                </Slider.Style>
                <i:Interaction.Triggers>
                  <i:EventTrigger EventName="PreviewMouseLeftButtonUp">
                    <i:InvokeCommandAction Command="{Binding SliderChangedCommand}"
                                           CommandParameter="{Binding Value, RelativeSource={RelativeSource AncestorType=Slider}}" />
                  </i:EventTrigger>
                </i:Interaction.Triggers>
              </Slider>
            </Grid>

            <ComboBox Grid.Row="2"
                      ItemsSource="{Binding AvailableSounds}"
                      SelectedItem="{Binding SelectedSound}"
                      Margin="20,5,0,0"
                      Width="200"
                      HorizontalAlignment="Left"
                      IsEnabled="{Binding CanSelectSound}">
              <ComboBox.Style>
                <Style TargetType="ComboBox"
                       BasedOn="{StaticResource {x:Type ComboBox}}">
                  <Style.Triggers>
                    <Trigger Property="UIElement.IsEnabled"
                             Value="False">
                      <Setter Property="Opacity"
                              Value="0.4" />
                    </Trigger>
                  </Style.Triggers>
                </Style>
              </ComboBox.Style>
            </ComboBox>
          </Grid>
        </Expander>

        <Expander Header="Regex"
                  Grid.Row="2"
                  IsExpanded="{Binding IsRegexExpanded, Mode=TwoWay}"
                  Margin="10">
          <StackPanel>
            <!-- Liste der Regex -->
            <ItemsControl ItemsSource="{Binding RegexItems}"
                          Margin="20,0,20,0">
              <ItemsControl.ItemTemplate>
                <DataTemplate>

                  <StackPanel Margin="0,0,0,15">

                    <StackPanel Orientation="Horizontal">
                      <!-- Anzeige -->
                      <TextBlock Text="{Binding RegexTitle}"
                                 FontWeight="SemiBold"
                                 VerticalAlignment="Center" />

                      <Button Width="25"
                              Height="25"
                              Margin="5,0,0,0"
                              Command="{Binding DataContext.RemoveRegexCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                              CommandParameter="{Binding}"
                              Style="{StaticResource MahApps.Styles.Button.Circle}"
                              BorderBrush="{DynamicResource MahApps.Brushes.Gray3}"
                              BorderThickness="1"
                              HorizontalAlignment="Left"
                              ToolTip="Remove Regex">

                        <iconPacks:PackIconMaterial Kind="Minus"
                                                    Foreground="Red"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center" />
                      </Button>
                    </StackPanel>

                    <Grid Margin="0,5,0,0">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>

                      <!-- Regex Eingabe -->
                      <TextBox Text="{Binding RegexPattern, UpdateSourceTrigger=PropertyChanged}"
                               Grid.Column="0"
                               AcceptsReturn="False"
                               Height="30"
                               VerticalContentAlignment="Center" />

                      <Button BorderThickness="1"
                              Grid.Column="1"
                              Margin="5,0,0,0"
                              ToolTip="Copy Regex"
                              Command="{Binding DataContext.CopyRegexCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                              CommandParameter="{Binding}">
                        <Button.Style>
                          <Style TargetType="Button"
                                 BasedOn="{StaticResource MahApps.Styles.Button}">
                            <Setter Property="Content">
                              <Setter.Value>
                                <iconPacks:PackIconMaterial Kind="ContentCopy"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center" />
                              </Setter.Value>
                            </Setter>
                            <Setter Property="BorderBrush"
                                    Value="{DynamicResource MahApps.Brushes.Gray3}" />
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding IsCopiedToClipboard}"
                                           Value="True">
                                <Setter Property="Content">
                                  <Setter.Value>
                                    <iconPacks:PackIconMaterial Kind="CheckBold"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center" />
                                  </Setter.Value>
                                </Setter>
                                <Setter Property="Foreground"
                                        Value="Green" />
                                <Setter Property="BorderThickness"
                                        Value="2" />
                                <Setter Property="Foreground"
                                        Value="Green" />
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </Button.Style>
                      </Button>
                    </Grid>
                  </StackPanel>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Add Button -->
            <Button Width="25"
                    Height="25"
                    Margin="20,0,0,0"
                    Command="{Binding AddRegexCommand}"
                    BorderBrush="{DynamicResource MahApps.Brushes.Gray3}"
                    BorderThickness="1"
                    HorizontalAlignment="Left"
                    ToolTip="Add Regex"
                    Style="{StaticResource MahApps.Styles.Button.Circle}">

              <iconPacks:PackIconMaterial Kind="Plus"
                                          Foreground="Green"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
            </Button>
          </StackPanel>
        </Expander>

        <Expander Header="Update"
                  Grid.Row="4"
                  Margin="10"
                  IsExpanded="False">
          <StackPanel Margin="20,0,20,0" Orientation="Horizontal" >
            <TextBlock Text="App version: " />
            <TextBlock Text="{Binding CurrentAppVersion}" />
          </StackPanel>
        </Expander>

        <Expander Grid.Row="6"
                  Margin="10"
                  IsExpanded="False">
          <Expander.Header>
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center">
              <TextBlock Text="❤️"
                         Foreground="Red"
                         FontSize="16"
                         Margin="0,0,5,0" />
              <TextBlock Text="Support"
                         FontSize="14"
                         VerticalAlignment="Center" />
            </StackPanel>
          </Expander.Header>
          <StackPanel Margin="20,0,20,0"
                      HorizontalAlignment="Left">
            <TextBlock Text="If you like the app, you can support it!"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Left"
                       Margin="0,0,0,10" />
            <Button Content="Buy me a coffee"
                    HorizontalAlignment="Left"
                    Width="150"/>
          </StackPanel>
        </Expander>
      </Grid>
    </ScrollViewer>

    <Button Grid.Row="1"
            Margin="10"
            Content="Save"
            Style="{StaticResource MahApps.Styles.Button.Circle}"
            Command="{Binding SaveCommand}"
            Width="44"
            Height="44" />
  </Grid>
</mah:MetroWindow>