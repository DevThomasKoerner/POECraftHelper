<mah:MetroWindow x:Class="POECraftHelper.Views.CraftHelperView"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
                 xmlns:local="clr-namespace:POECraftHelper.Views"
                 xmlns:controls="clr-namespace:POECraftHelper.Controls"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:converters="clr-namespace:POECraftHelper.Converters"
                 xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
                 mc:Ignorable="d"
                 WindowStyle="None"
                 AllowsTransparency="True"
                 ShowTitleBar="False"
                 ShowCloseButton="False"
                 ShowMinButton="False"
                 ShowMaxRestoreButton="False"
                 Background="Transparent"
                 BorderThickness="0"
                 ResizeMode="NoResize"
                 Topmost="True"
                 MinHeight="150"
                 MinWidth="150"
                 Height="{Binding WindowHeight, Mode=TwoWay}"
                 Width="{Binding WindowWidth, Mode=TwoWay}"
                 Left="{Binding WindowLeft, Mode=TwoWay}"
                 Top="{Binding WindowTop, Mode=TwoWay}">

  <mah:MetroWindow.Resources>
    <ResourceDictionary>
      <SolidColorBrush x:Key="BackgroundBrush"
                       Color="#CC000000" />

      <converters:BoolToVisibilityConverter x:Key="_booleanToVisibilityConverter" />
      
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Controls.xaml" />
        <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Fonts.xaml" />
        <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Themes/Dark.Amber.xaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </mah:MetroWindow.Resources>

  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="Auto" />
      <ColumnDefinition Width="*" />
      <ColumnDefinition Width="Auto" />
    </Grid.ColumnDefinitions>

    <controls:OverlayControl Visibility="{Binding IsOverlayVisible, Converter={StaticResource _booleanToVisibilityConverter}}"
                             CurrentDetectionResult="{Binding CurrentDetectionResult}"
                             Grid.ColumnSpan="3"
                             OkayCommand="{Binding OkayCommand}"
                             IsOkayEnabled="{Binding IsOkayEnabled}"
                             Panel.ZIndex="100"/>
    
    <StackPanel Grid.Column="0"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom">
      <Button Command="{Binding MinimizeCommand}"
              IsEnabled="{Binding CanMinimize}"
              ToolTip="Minimize"
              Width="30"
              Height="30"
              BorderBrush="{DynamicResource MahApps.Brushes.Gray3}"
              BorderThickness="2"
              Grid.Column="0"
              Margin="0,0,0,5">
        <mah:FontIcon FontFamily="Segoe MDL2 Assets"
                      Glyph="&#xE921;"
                      Foreground="White"
                      FontSize="15" />
        <Button.Style>
          <Style TargetType="Button"
                 BasedOn="{StaticResource MahApps.Styles.Button}">
            <Setter Property="Background"
                    Value="{DynamicResource MahApps.Brushes.ThemeBackground}" />
            <Style.Triggers>
              <Trigger Property="IsEnabled"
                       Value="False">
                <Setter Property="Opacity"
                        Value="0.3" />
              </Trigger>
            </Style.Triggers>
          </Style>
        </Button.Style>
      </Button>

      <Button Command="{Binding ExitCommand}"
              IsEnabled="{Binding CanExit}"
              ToolTip="Exit"
              Width="30"
              Height="30"
              BorderBrush="{DynamicResource MahApps.Brushes.Gray3}"
              BorderThickness="2"
              HorizontalAlignment="Left"
              VerticalAlignment="Bottom"
              Margin="0,0,0,5">
        <mah:FontIcon FontFamily="Segoe MDL2 Assets"
                      Glyph="&#xE711;"
                      Foreground="White"
                      FontSize="15" />
        <Button.Style>
          <Style TargetType="Button"
                 BasedOn="{StaticResource MahApps.Styles.Button}">
            <Setter Property="Background"
                    Value="{DynamicResource MahApps.Brushes.ThemeBackground}" />
            <Style.Triggers>
              <Trigger Property="IsEnabled"
                       Value="False">
                <Setter Property="Opacity"
                        Value="0.3" />
              </Trigger>
            </Style.Triggers>
          </Style>
        </Button.Style>
      </Button>

      <controls:WindowDragControl HorizontalAlignment="Left"
                                  VerticalAlignment="Bottom"
                                  Panel.ZIndex="10"
                                  Margin="2,0,0,10"
                                  IsDragEnabled="{Binding CanDrag}"
                                  TargetElement="{Binding ElementName=_detectionArea}"
                                  Bounds="{Binding DetectionArea, Mode=TwoWay}" />
    </StackPanel>

    <Grid Grid.Column="1">
      <controls:WindowResizeControl HorizontalAlignment="Center"
                                    VerticalAlignment="Bottom"
                                    Panel.ZIndex="10"
                                    IsVertical="True"
                                    IsResizeEnabled="{Binding CanResize}"
                                    TargetElement="{Binding ElementName=_detectionArea}"
                                    Bounds="{Binding DetectionArea, Mode=TwoWay}" />

      <controls:WindowResizeControl HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Panel.ZIndex="10"
                                    Margin="-10,-30,0,0"
                                    IsResizeEnabled="{Binding CanResize}"
                                    IsVertical="False"
                                    TargetElement="{Binding ElementName=_detectionArea}"
                                    Bounds="{Binding DetectionArea, Mode=TwoWay}" />

      <!-- Seiten + unten -->
      <Border x:Name="_detectionArea"
              Margin="22,0,20,30"
              BorderThickness="3,0,3,3"
              Background="Transparent">
        <Border.Style>
          <Style TargetType="Border">
            <!-- Default -->
            <Setter Property="BorderBrush"
                    Value="LightGray" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding IsRunning}"
                           Value="True">
                <Setter Property="BorderBrush"
                        Value="Green" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </Border.Style>
      </Border>
      <Border BorderBrush="{StaticResource BackgroundBrush}"
              BorderThickness="20,0,20,20"
              Background="Transparent"
              Margin="2,0,0,10">
      </Border>
    </Grid>

    <StackPanel Grid.Column="2"
                Orientation="Vertical"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="2,0,0,10">
      <!--Settings button-->
      <Button HorizontalAlignment="Right"
              VerticalAlignment="Bottom"
              Style="{StaticResource MahApps.Styles.Button.Circle}"
              Command="{Binding SettingsCommand}"
              CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
              IsEnabled="{Binding CanSettings}"
              ToolTip="Settings"
              Width="40"
              Height="40"
              Margin="0,0,0,5"
              Background="{DynamicResource MahApps.Brushes.ThemeBackground}">

        <iconPacks:PackIconMaterial Kind="Cog"
                                    Width="20"
                                    Height="20" />
      </Button>

      <!--Start button-->
      <Button Command="{Binding StartStopCommand}"
              IsEnabled="{Binding CanStartStop}"
              Content="{Binding StartStopText}"
              ToolTip="Start regex detection"
              Width="40"
              Height="40">
        <Button.Style>
          <Style TargetType="Button"
                 BasedOn="{StaticResource MahApps.Styles.Button.Circle}">
            <Setter Property="Background"
                    Value="{DynamicResource MahApps.Brushes.ThemeBackground}" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding IsRunning}"
                           Value="True">
                <Setter Property="Background"
                        Value="Green" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </Button.Style>
      </Button>
    </StackPanel>
  </Grid>
</mah:MetroWindow>
